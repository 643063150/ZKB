# =============================================================================
# ZKB 部署环境变量模板
# 复制为 .env 后按需修改
# =============================================================================

# ---- 端口配置 ---------------------------------------------------------------
QD_PORT=6333          # Qdrant REST API 端口
RAG_PORT=8000         # RAG Service (FastAPI) 端口
GW_PORT=8080          # Knowledge Gateway (Go/Gin) 端口
UI_PORT=80            # 前端 Nginx 端口

# ---- Qdrant -----------------------------------------------------------------
QDRANT_URL=http://qdrant:6333              # Docker: 容器名; native: http://localhost:6333
QDRANT_COLLECTION=knowledge_items

# ---- RAG Service (Python/FastAPI) -------------------------------------------
# LLM — 文档分类用（运行时可通过 PUT /config/llm 动态切换）
LLM_MODEL=LongCat-Flash-Chat
LLM_BASE_URL=https://api.longcat.chat/openai/v1
LLM_API_KEY=your-llm-key-here

# Embedding — 主 Provider
EMBED_MODEL=gemini-embedding-001
EMBED_DIM=3072
EMBED_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
EMBED_API_KEY=your-embed-key-here

# Embedding — 备用 Provider（主限流时自动切换）
EMBED_MODEL_FALLBACK=embedding-2
EMBED_BASE_URL_FALLBACK=https://open.bigmodel.cn/api/paas/v4/
EMBED_API_KEY_FALLBACK=your-fallback-key-here

# Chunking
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# ---- Knowledge Gateway (Go/Gin) ---------------------------------------------
SERVER_PORT=8080
PYTHON_BASE_URL=http://rag:8000            # Docker: http://rag:8000; native: http://localhost:8000

# ---- Provider 持久化文件路径 (可选) ------------------------------------------
# PROVIDER_CONFIG_PATH=/app/provider_config.json
